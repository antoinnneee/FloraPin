---
// Barre de navigation basse de l'app, reproduite pour les mockups d'écran.
// Les cinq onglets et leurs icônes botaniques suivent app/.../navigation/BottomNavBar.kt :
// aplats verts (#386A53) rehaussés d'une corolle bleu-lavande à cœur jaune.
interface Props {
  /** Onglet mis en avant (indicateur Material 3). */
  active: 'home' | 'albums' | 'map' | 'feed' | 'profile';
}

const { active } = Astro.props;

const tabs = [
  { key: 'home', label: 'Accueil' },
  { key: 'albums', label: 'Albums' },
  { key: 'map', label: 'Carte' },
  { key: 'feed', label: 'Partagées' },
  { key: 'profile', label: 'Profil' },
] as const;

const VERT = '#386A53';
const VERT_CLAIR = '#4e8064';
const PETALE = '#6c7fd0';
const COEUR = '#f2d24e';

// Corolle à cinq pétales : le motif commun à toutes les icônes de l'app.
const fleur = (cx: number, cy: number, r: number) =>
  [0, 72, 144, 216, 288]
    .map((a) => {
      const rad = ((a - 90) * Math.PI) / 180;
      return `<circle cx="${(cx + Math.cos(rad) * r).toFixed(2)}" cy="${(cy + Math.sin(rad) * r).toFixed(2)}" r="${r * 0.72}" fill="${PETALE}"/>`;
    })
    .join('') + `<circle cx="${cx}" cy="${cy}" r="${r * 0.62}" fill="${COEUR}"/>`;

const icons: Record<string, string> = {
  home: `<path d="M3.6 11.6 12 5.1l8.4 6.5V20a1 1 0 0 1-1 1h-4.6v-5.2H9.2V21H4.6a1 1 0 0 1-1-1z" fill="${VERT}"/>
         <path d="M9.2 15.8h5.2V21H9.2z" fill="${VERT_CLAIR}"/>${fleur(12, 3.4, 1.5)}`,
  albums: `<rect x="2.6" y="8.4" width="11.6" height="11.6" rx="2" fill="${VERT_CLAIR}"/>
           <rect x="7.4" y="5.6" width="11.6" height="11.6" rx="2" fill="${VERT}"/>${fleur(18.4, 5.4, 1.7)}`,
  map: `<path d="M12 22.2c0 0 7.2-7.1 7.2-12.2A7.2 7.2 0 0 0 4.8 10c0 5.1 7.2 12.2 7.2 12.2z" fill="${VERT}"/>
        <circle cx="12" cy="9.8" r="4.6" fill="#fbfdfb"/>${fleur(12, 9.8, 1.9)}`,
  feed: `<path d="M12 21.6c0-4.2-.2-6.6-.2-9.4" stroke="${VERT}" stroke-width="1.7" stroke-linecap="round" fill="none"/>
         <path d="M11.8 15.6c-1.9.2-3.4-.9-4-2.7 1.9-.5 3.6.5 4 2.7z" fill="${VERT_CLAIR}"/>
         <path d="M12 13.4c1.4-1.3 1.6-3.1.7-4.7-1.4.9-1.9 2.7-.7 4.7z" stroke="${VERT}" stroke-width="1.2" fill="none"/>${fleur(8.3, 7.6, 2.5)}${fleur(15.7, 5.9, 2.5)}`,
  profile: `<circle cx="12" cy="7.2" r="3.7" fill="${VERT}"/>
            <path d="M4.4 21.4c0-4.2 3.4-6.8 7.6-6.8s7.6 2.6 7.6 6.8z" fill="${VERT}"/>${fleur(17.6, 16.4, 1.7)}`,
};
---

<nav class="nav" aria-hidden="true">
  {tabs.map((t) => (
    <span class:list={['tab', { on: t.key === active }]}>
      <span class="pill">
        <svg viewBox="0 0 24 24" set:html={icons[t.key]} />
      </span>
      <span class="lbl">{t.label}</span>
    </span>
  ))}
</nav>

<style>
  .nav {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    align-items: center;
    background: #f2f6f1;
    border-top: 1px solid #dce5dd;
    padding: 0.5em 0 0.7em;
  }

  .tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25em;
  }

  /* Indicateur Material 3 : pastille derrière l'icône de l'onglet courant. */
  .pill {
    display: grid;
    place-items: center;
    width: 2.9em;
    height: 1.9em;
    border-radius: 100px;
  }

  .tab.on .pill {
    background: #d5e8dc;
  }

  .pill svg {
    width: 1.55em;
    height: 1.55em;
  }

  .tab:not(.on) .pill svg {
    opacity: 0.62;
  }

  .lbl {
    font-size: 0.72em;
    line-height: 1;
    color: #404943;
  }

  .tab.on .lbl {
    color: #052014;
    font-weight: 700;
  }
</style>
