# Copier en .env et adapter. Ne jamais committer le .env réel.

# API
PORT=3000

# PostgreSQL + PostGIS
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=florapin
DATABASE_PASSWORD=change-me
DATABASE_NAME=florapin

# JWT (générer des secrets longs et aléatoires)
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_TTL=30d
