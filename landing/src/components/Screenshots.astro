---
// Cadres en attente des vraies captures ; chaque écran garde une légère
// inclinaison, comme des photos posées sur une table.
const screens = [
  { label: 'Galerie',      icon: '🖼️', tilt: -2.5 },
  { label: 'Carte',        icon: '🗺️', tilt: 1.5 },
  { label: 'Détail fleur', icon: '🌸', tilt: -1 },
  { label: 'Partage',      icon: '👥', tilt: 2.5 },
];
---

<section class="screenshots">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Aperçu</span>
      <h2>L'app <em>en images</em></h2>
      <p class="note">Captures d'écran à venir avant le lancement de la bêta.</p>
    </div>
    <div class="gallery">
      {screens.map((s, i) => (
        <div class="screen-frame reveal" style={`--tilt:${s.tilt}deg; transition-delay:${i * 0.08}s`}>
          <div class="notch"></div>
          <div class="screen-inner">
            <span class="screen-icon">{s.icon}</span>
            <span class="screen-label">{s.label}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .screenshots {
    padding: var(--section-py) 0;
    background: var(--tilleul);
  }

  .section-header .note {
    margin-top: 12px;
    font-size: 0.88rem;
    color: var(--texte-doux);
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(18px, 3vw, 32px);
    align-items: start;
  }

  .screen-frame {
    background: var(--encre);
    border-radius: 26px;
    padding: 8px;
    box-shadow: 0 20px 48px rgba(19, 42, 29, 0.22);
    aspect-ratio: 9 / 18;
    display: flex;
    flex-direction: column;
    rotate: var(--tilt);
    transition: rotate 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.7s ease, box-shadow 0.3s;
  }

  .screen-frame:hover {
    rotate: 0deg;
    transform: translateY(-6px);
    box-shadow: 0 28px 60px rgba(19, 42, 29, 0.3);
  }

  .notch {
    width: 40px;
    height: 4px;
    background: rgba(237, 243, 227, 0.18);
    border-radius: 3px;
    margin: 6px auto;
  }

  .screen-inner {
    flex: 1;
    background: var(--papier);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    border: 2px dashed var(--tilleul-2);
  }

  .screen-icon {
    font-size: 2.4rem;
    line-height: 1;
  }

  .screen-label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 500;
    color: var(--feuille);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  @media (max-width: 720px) {
    .gallery { grid-template-columns: repeat(2, 1fr); }
  }
</style>
