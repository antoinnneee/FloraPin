# Signature release FloraPin (NODE-119) — MODÈLE.
# Copier en `keystore.properties` (gitignoré) à la racine du dépôt, ou fournir
# les mêmes clés via variables d'environnement (CI). Tant que ce fichier est
# absent, le build release reste NON SIGNÉ (la config de signature n'est pas posée).
#
# Générer un keystore (hors dépôt) :
#   keytool -genkeypair -v -keystore florapin-release.jks \
#     -alias florapin -keyalg RSA -keysize 2048 -validity 10000
#
# RELEASE_STORE_FILE est résolu depuis la racine du projet.

RELEASE_STORE_FILE=florapin-release.jks
RELEASE_STORE_PASSWORD=changeme
RELEASE_KEY_ALIAS=florapin
RELEASE_KEY_PASSWORD=changeme
