---
import DownloadButton from './DownloadButton.astro';

// Épingles-fleurs de la scène : position (en % du panneau), teinte des pétales,
// délai d'éclosion (la séquence suit le tracé du sentier).
const pins = [
  { top: 86, left: 34, petal: '#f9faf4', delay: 0.9 },
  { top: 44, left: 30, petal: '#d5548c', delay: 1.3 },
  { top: 62, left: 58, petal: '#c9a3e8', delay: 1.7 },
  { top: 26, left: 74, petal: '#d5548c', delay: 2.1 },
  { top: 12, left: 42, petal: '#f9faf4', delay: 2.5 },
];
---

<section class="hero">
  <!-- Courbes de niveau, sur toute la largeur -->
  <svg class="contours" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <g fill="none" stroke="rgba(237, 243, 227, 0.07)" stroke-width="1.5">
      <path d="M-60 720 C 240 640, 420 760, 720 690 S 1250 600, 1520 680" />
      <path d="M-60 620 C 260 540, 460 660, 760 590 S 1270 500, 1520 580" />
      <path d="M-60 520 C 280 440, 500 560, 800 490 S 1290 400, 1520 480" />
      <path d="M-60 420 C 300 340, 540 460, 840 390 S 1310 300, 1520 380" />
      <path d="M-60 320 C 320 240, 580 360, 880 290 S 1330 200, 1520 280" />
      <path d="M-60 220 C 340 140, 620 260, 920 190 S 1350 100, 1520 180" />
      <path d="M240 900 C 200 700, 360 560, 300 380 S 380 120, 300 -40" />
      <path d="M1120 900 C 1160 720, 1020 580, 1090 400 S 1010 140, 1100 -40" />
    </g>
  </svg>

  <!-- Panneau de droite : les fleurs épinglées (le sentier global passe ici) -->
  <div class="scene" aria-hidden="true">
    {pins.map((p) => (
      <div class="pin" style={`top:${p.top}%; left:${p.left}%; --bloom-delay:${p.delay}s;`}>
        <svg viewBox="0 0 44 60" width="44" height="60">
          <line x1="22" y1="30" x2="22" y2="54" stroke="rgba(237,243,227,0.55)" stroke-width="2" stroke-linecap="round" />
          <ellipse cx="22" cy="56" rx="5" ry="2" fill="rgba(0,0,0,0.28)" />
          <g class="flower" style={`--petal:${p.petal}`}>
            <ellipse cx="22" cy="9"  rx="5.5" ry="9"  fill={p.petal} transform="rotate(0 22 18)" />
            <ellipse cx="22" cy="9"  rx="5.5" ry="9"  fill={p.petal} transform="rotate(72 22 18)" />
            <ellipse cx="22" cy="9"  rx="5.5" ry="9"  fill={p.petal} transform="rotate(144 22 18)" />
            <ellipse cx="22" cy="9"  rx="5.5" ry="9"  fill={p.petal} transform="rotate(216 22 18)" />
            <ellipse cx="22" cy="9"  rx="5.5" ry="9"  fill={p.petal} transform="rotate(288 22 18)" />
            <circle cx="22" cy="18" r="4.5" fill="var(--pollen)" />
          </g>
        </svg>
      </div>
    ))}

    <!-- Regroupement, comme sur la carte de l'app -->
    <div class="cluster">3</div>

    <!-- L'ami qui identifie la fleur : le côté social, dans le hero -->
    <div class="comment">
      <span class="avatar">M</span>
      <div class="comment-body">
        <p class="comment-text">« Une anémone sylvie ! »</p>
        <p class="comment-meta">Marion · à l'instant</p>
      </div>
      <span class="hearts">♥ 12</span>
    </div>
  </div>

  <div class="container">
    <div class="hero-text">
      <p class="coords">45.7640° N · 4.8357° E — quelque part en sous-bois</p>
      <h1>
        Vos fleurs,<br />
        <em>géolocalisées</em><br />
        et gardées pour toujours.
      </h1>
      <p class="subtitle">
        Photographiez chaque fleur que vous croisez, retrouvez-la sur une carte,
        et partagez-la avec une communauté d'amis passionnés — même sans réseau.
      </p>
      <div class="cta-group">
        <DownloadButton />
        <a href="#beta" class="btn-ghost">Rejoindre la bêta ↓</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    background:
      radial-gradient(ellipse 90% 70% at 78% 30%, rgba(46, 102, 71, 0.55) 0%, transparent 60%),
      linear-gradient(165deg, var(--sapin) 0%, var(--encre) 78%);
    overflow: hidden;
    padding: clamp(80px, 10vw, 120px) 0;
  }

  .contours {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* --- Texte --- */

  .hero-text {
    position: relative;
    z-index: 2;
    max-width: 580px;
    animation: rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .coords {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pollen);
    margin-bottom: 22px;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5.6vw, 4.4rem);
    font-weight: 560;
    line-height: 1.06;
    letter-spacing: -0.015em;
    color: var(--tilleul);
    margin-bottom: 26px;
  }

  h1 em {
    font-style: italic;
    font-weight: 460;
    color: var(--rose);
  }

  .subtitle {
    font-size: clamp(1rem, 1.4vw, 1.12rem);
    color: var(--mousse);
    max-width: 470px;
    margin-bottom: 40px;
    line-height: 1.75;
  }

  .cta-group {
    display: flex;
    align-items: center;
    gap: 26px;
    flex-wrap: wrap;
    color: var(--mousse); /* hérité par la mention bêta du bouton */
  }

  .btn-ghost {
    color: var(--tilleul);
    font-weight: 700;
    font-size: 0.95rem;
    padding-bottom: 3px;
    border-bottom: 2px solid rgba(237, 243, 227, 0.25);
    transition: border-color 0.2s;
  }

  .btn-ghost:hover { border-color: var(--pollen); }

  /* --- Scène : sentier + épingles-fleurs --- */

  .scene {
    position: absolute;
    z-index: 1;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(52vw, 720px);
    pointer-events: none;
  }

  .pin {
    position: absolute;
    transform: translate(-50%, -100%);
    filter: drop-shadow(0 6px 14px rgba(0, 0, 0, 0.35));
  }

  .pin .flower {
    transform-origin: 22px 18px;
    animation:
      bloom 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) var(--bloom-delay) both,
      sway 5s ease-in-out calc(var(--bloom-delay) + 0.8s) infinite;
  }

  .cluster {
    position: absolute;
    top: 24%;
    left: 58%;
    width: 34px;
    height: 34px;
    background: var(--feuille);
    color: var(--tilleul);
    font-weight: 700;
    font-size: 0.78rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(237, 243, 227, 0.7);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.3);
    animation: bloom 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) 2.8s both;
  }

  /* --- Bulle sociale --- */

  .comment {
    position: absolute;
    top: 66%;
    left: 50%;
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(249, 250, 244, 0.94);
    border-radius: 14px;
    padding: 12px 16px;
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.35);
    animation: pop 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) 3.2s both;
  }

  .avatar {
    width: 34px;
    height: 34px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--rose);
    color: var(--papier);
    font-weight: 700;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .comment-text {
    font-size: 0.86rem;
    font-weight: 700;
    color: var(--encre);
    line-height: 1.3;
  }

  .comment-meta {
    font-size: 0.7rem;
    color: var(--texte-doux);
  }

  .hearts {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--rose);
    background: var(--rose-doux);
    border-radius: 100px;
    padding: 4px 10px;
    white-space: nowrap;
  }

  /* --- Animations --- */

  @keyframes rise {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: none; }
  }

  @keyframes bloom {
    from { opacity: 0; transform: scale(0) rotate(-40deg); }
    to   { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  @keyframes sway {
    0%, 100% { transform: rotate(0deg); }
    50%      { transform: rotate(6deg); }
  }

  @keyframes pop {
    from { opacity: 0; transform: translateY(14px) scale(0.9); }
    to   { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-text,
    .pin .flower,
    .cluster,
    .comment {
      animation: none;
      opacity: 1;
    }
  }

  /* --- Responsive --- */

  @media (max-width: 960px) {
    .scene { width: 60vw; opacity: 0.8; }
    .comment { left: 34%; }
  }

  @media (max-width: 720px) {
    .hero {
      min-height: auto;
      padding-top: clamp(320px, 78vw, 420px);
      padding-bottom: 72px;
    }

    .scene {
      width: 100%;
      height: clamp(300px, 72vw, 400px);
      bottom: auto;
      opacity: 1;
    }

    .comment {
      top: 62%;
      left: 46%;
      transform: scale(0.92);
      transform-origin: top left;
    }

    .hero-text {
      max-width: 100%;
      text-align: center;
    }

    .subtitle { margin-left: auto; margin-right: auto; }
    .cta-group {
      justify-content: center;
      flex-direction: column;
      gap: 18px;
    }
  }
</style>
