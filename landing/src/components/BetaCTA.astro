---
import DownloadButton from './DownloadButton.astro';
---

<section id="beta" class="beta-cta">
  <div class="container">
    <div class="inner">
      <span class="hero-emoji" aria-hidden="true">🌸</span>
      <h2>Prêt à cataloguer vos fleurs ?</h2>
      <p>Rejoignez la bêta et soyez parmi les premiers à essayer FloraPin.</p>

      <div class="dl-wrap">
        <DownloadButton />
      </div>
    </div>
  </div>
</section>

<style>
  .beta-cta {
    padding: var(--section-py) 0;
    background: linear-gradient(140deg, var(--green-50) 0%, #fff3fa 100%);
  }

  .inner {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .hero-emoji {
    font-size: 3.2rem;
    display: block;
    margin-bottom: 20px;
    line-height: 1;
  }

  h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--green-900);
    margin-bottom: 12px;
  }

  p {
    font-size: 1rem;
    color: var(--gray-600);
    margin-bottom: 32px;
  }

  .dl-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 0;
  }
</style>
