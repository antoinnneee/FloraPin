<section class="hero">
  <div class="container">
    <div class="hero-content">

      <div class="hero-text">
        <div class="badge">🌿 Bêta — Rejoignez les premiers</div>
        <h1>
          Vos fleurs,<br />
          <span class="accent">géolocalisées</span><br />
          et gardées pour toujours.
        </h1>
        <p class="subtitle">
          Photographiez chaque fleur que vous croisez, retrouvez-la sur une carte,
          et partagez-la avec une communauté d'amis passionnés — même sans réseau.
        </p>
        <div class="cta-group">
          <a href="#beta" class="btn-primary">🌸 Rejoindre la bêta</a>
          <a href="#fonctionnalites" class="btn-ghost">Découvrir l'app ↓</a>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="glow"></div>
        <div class="phone">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <div class="app-header">🌸 FloraPin</div>
            <div class="map-area">
              <div class="map-bg"></div>
              <span class="pin pin-1">🌸</span>
              <span class="pin pin-2">🌼</span>
              <span class="pin pin-3">🌺</span>
              <span class="pin pin-4">🌻</span>
              <div class="cluster">3</div>
            </div>
            <div class="bottom-bar">
              <span>🏠</span>
              <span class="active">🗺️</span>
              <span>🖼️</span>
              <span>👤</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(140deg, var(--green-50) 0%, #fff5fb 100%);
    padding: var(--section-py) 0 calc(var(--section-py) * 0.75);
    overflow: hidden;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -80px;
    width: 560px;
    height: 560px;
    background: radial-gradient(circle, rgba(236, 72, 153, 0.07) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  /* --- Texte --- */

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--green-100);
    color: var(--green-800);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 24px;
    border: 1px solid var(--green-200);
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--green-900);
    margin-bottom: 20px;
  }

  .accent { color: var(--pink-500); }

  .subtitle {
    font-size: 1.05rem;
    color: var(--gray-600);
    max-width: 460px;
    margin-bottom: 36px;
    line-height: 1.75;
  }

  .cta-group {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--green-700);
    color: var(--white);
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 28px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(21, 128, 61, 0.28);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .btn-primary:hover {
    background: var(--green-800);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(21, 128, 61, 0.36);
  }

  .btn-ghost {
    color: var(--green-700);
    font-weight: 600;
    font-size: 0.95rem;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s;
  }

  .btn-ghost:hover { border-color: var(--green-500); }

  /* --- Maquette téléphone --- */

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 24px 0;
  }

  .glow {
    position: absolute;
    inset: 5%;
    background: radial-gradient(ellipse, rgba(34, 197, 94, 0.18) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(32px);
    z-index: 0;
  }

  .phone {
    position: relative;
    z-index: 1;
    width: 230px;
    height: 470px;
    background: var(--green-900);
    border-radius: 36px;
    padding: 10px;
    box-shadow:
      0 32px 80px rgba(0, 0, 0, 0.24),
      0 0 0 1px rgba(255, 255, 255, 0.07),
      inset 0 0 0 2px rgba(255, 255, 255, 0.04);
  }

  .phone-notch {
    width: 56px;
    height: 5px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 4px;
    margin: 0 auto 8px;
  }

  .phone-screen {
    background: var(--green-50);
    border-radius: 28px;
    height: calc(100% - 21px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .app-header {
    background: var(--white);
    padding: 12px 16px;
    font-weight: 700;
    font-size: 0.82rem;
    color: var(--green-900);
    border-bottom: 1px solid var(--green-100);
  }

  .map-area {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  .map-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(187, 247, 208, 0.35) 1px, transparent 1px),
      linear-gradient(90deg, rgba(187, 247, 208, 0.35) 1px, transparent 1px);
    background-size: 22px 22px;
    background-color: #e4f4ea;
  }

  .pin {
    position: absolute;
    font-size: 1.3rem;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.18));
    animation: float 3s ease-in-out infinite;
  }

  .pin-1 { top: 22%; left: 18%; animation-delay: 0s; }
  .pin-2 { top: 42%; left: 62%; animation-delay: 0.6s; }
  .pin-3 { top: 66%; left: 32%; animation-delay: 1.1s; }
  .pin-4 { top: 18%; left: 68%; animation-delay: 1.7s; }

  .cluster {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 30px;
    height: 30px;
    background: var(--green-600);
    color: var(--white);
    font-weight: 700;
    font-size: 0.72rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--white);
    box-shadow: 0 2px 8px rgba(22, 163, 74, 0.45);
  }

  .bottom-bar {
    background: var(--white);
    display: flex;
    justify-content: space-around;
    padding: 10px 8px;
    border-top: 1px solid var(--green-100);
    font-size: 1rem;
  }

  .bottom-bar .active {
    background: var(--green-100);
    border-radius: 8px;
    padding: 2px 6px;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-5px); }
  }

  /* --- Responsive --- */

  @media (max-width: 800px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 48px;
      text-align: center;
    }

    .hero-text { order: 1; }
    .hero-visual { order: 0; }

    .subtitle { margin-left: auto; margin-right: auto; }
    .cta-group { justify-content: center; }

    .phone { width: 190px; height: 390px; }
  }
</style>
