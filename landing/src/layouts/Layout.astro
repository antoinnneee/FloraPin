---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'FloraPin — Géolocalisez et partagez vos fleurs',
  description = 'Photographiez chaque fleur que vous croisez, retrouvez-la sur une carte, et partagez vos plus belles trouvailles avec vos amis — même sans réseau.',
  image = '/og-image.png',
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://florapin.pattounecorp.ovh');
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImage = new URL(image, siteUrl);
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "FloraPin",
      "description": description,
      "applicationCategory": "LifestyleApplication",
      "operatingSystem": "Android",
      "offers": { "@type": "Offer", "price": "0" },
      "url": siteUrl.href,
    })} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Font : Inter via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --green-900: #14532d;
    --green-800: #166534;
    --green-700: #15803d;
    --green-600: #16a34a;
    --green-500: #22c55e;
    --green-200: #bbf7d0;
    --green-100: #dcfce7;
    --green-50:  #f0fdf4;
    --pink-500:  #ec4899;
    --pink-100:  #fce7f3;
    --white:     #ffffff;
    --gray-50:   #f9fafb;
    --gray-100:  #f3f4f6;
    --gray-200:  #e5e7eb;
    --gray-600:  #4b5563;
    --gray-900:  #111827;

    --font:      'Inter', system-ui, -apple-system, sans-serif;
    --max-w:     1120px;
    --section-py: clamp(64px, 8vw, 112px);
    --radius:    16px;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font);
    color: var(--gray-900);
    background: var(--white);
    -webkit-font-smoothing: antialiased;
    line-height: 1.6;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 48px);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .eyebrow {
    display: inline-block;
    color: var(--green-700);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-header h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--green-900);
    line-height: 1.25;
    max-width: 560px;
    margin: 0 auto;
  }
</style>
