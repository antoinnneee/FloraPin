# Déploiement FloraPin — copier en .env (à côté de docker-compose.yml).
# Ne jamais committer le .env réel.

# Domaine public (DNS pointant vers le VPS) — HTTPS auto par Caddy.
DOMAIN=florapin.example.com

# --- Ports ---
# Ports publics du reverse-proxy Caddy (changez-les si 80/443 sont déjà pris).
HTTP_PORT=80
HTTPS_PORT=443
# Port interne de l'API NestJS (réseau Docker + cible du reverse-proxy Caddy).
API_PORT=3000
# Ports publiés sur l'HÔTE uniquement en DEV (docker-compose.override.yml) —
# inutilisés en prod (db/minio ne sont alors joignables que via le réseau Docker).
DB_HOST_PORT=5432
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# PostgreSQL / PostGIS
DATABASE_USER=florapin
DATABASE_PASSWORD=change-me-strong
DATABASE_NAME=florapin

# JWT (secrets longs et aléatoires)
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_TTL=30d

# Dashboard de supervision (/api/v1/admin/dashboard). Utiliser un secret long,
# différent des secrets JWT. Sans valeur, les données admin restent désactivées.
ADMIN_DASHBOARD_TOKEN=change-me-with-a-long-random-secret

# MinIO (stockage objet)
MINIO_ACCESS_KEY=florapin
MINIO_SECRET_KEY=change-me-strong
MINIO_BUCKET=florapin
# Endpoint PUBLIC pour les URLs présignées (joignable depuis l'appareil).
# Par défaut = ${DOMAIN} (le proxy route /{bucket}/* vers MinIO). À surcharger
# uniquement si MinIO est exposé sur un autre hôte/sous-domaine.
# MINIO_PUBLIC_ENDPOINT=florapin.example.com
# MINIO_PUBLIC_PORT=443
# MINIO_PUBLIC_USE_SSL=true

# Identification (optionnel)
PLANTNET_API_KEY=

# Notifications push Firebase Cloud Messaging. Laisser "stub" pour désactiver
# les envois. En production, utiliser "fcm" et renseigner les trois valeurs du
# compte de service sans committer le fichier .env réel.
PUSH_DRIVER=stub
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
# Coller private_key sur une seule ligne en conservant les séquences \n.
FCM_PRIVATE_KEY=
