---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="top">
      <div class="brand">
        <span class="logo">🌸 FloraPin</span>
        <p>Photographiez la nature, épinglez vos trouvailles.</p>
      </div>
      <nav class="links" aria-label="Liens du pied de page">
        <a href="mailto:contact@florapin.pattounecorp.ovh">Contact</a>
        <a href="/changelog">Nouveautés</a>
        <a href="/politique-de-confidentialite">Politique de confidentialité</a>
        <a href="/suppression-compte">Supprimer mon compte</a>
        <a
          href="https://github.com/antoinnneee/FloraPin"
          target="_blank"
          rel="noopener noreferrer"
        >GitHub ↗</a>
      </nav>
    </div>
    <div class="bottom">
      <p>© {year} FloraPin — Tous droits réservés.</p>
      <p class="coords">Cultivé quelque part entre 41° et 51° N.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--encre);
    color: var(--tilleul);
    padding: 56px 0 30px;
  }

  .top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 32px;
    flex-wrap: wrap;
    padding-bottom: 40px;
    border-bottom: 1px dashed rgba(237, 243, 227, 0.14);
    margin-bottom: 24px;
  }

  .logo {
    display: block;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 560;
    margin-bottom: 8px;
  }

  .brand p {
    font-size: 0.84rem;
    color: var(--mousse);
  }

  .links {
    display: flex;
    gap: 26px;
    flex-wrap: wrap;
    align-items: center;
  }

  .links a {
    font-size: 0.84rem;
    color: var(--mousse);
    transition: color 0.15s;
  }

  .links a:hover { color: var(--pollen); }

  .bottom {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .bottom p {
    font-size: 0.76rem;
    color: rgba(237, 243, 227, 0.4);
  }

  .bottom .coords {
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }
</style>
