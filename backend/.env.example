# Copier en .env et adapter. Ne jamais committer le .env réel.

# API
PORT=3000

# PostgreSQL + PostGIS
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=florapin
DATABASE_PASSWORD=change-me
DATABASE_NAME=florapin

# JWT (générer des secrets longs et aléatoires)
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_TTL=30d

# Identification d'espèces (Pl@ntNet). Sans clé : identification désactivée (stub).
PLANTNET_API_KEY=
PLANTNET_BASE_URL=https://my-api.plantnet.org

# Push (FCM/APNs). PUSH_DRIVER=stub (défaut) journalise sans envoyer.
# PUSH_DRIVER=fcm activera le provider Firebase (à venir) ; nécessite alors
# les credentials d'un projet Firebase (compte de service).
PUSH_DRIVER=stub
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=

# Stockage objet (MinIO / S3). STORAGE_DRIVER=stub pour désactiver en dev.
STORAGE_DRIVER=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=florapin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=florapin
STORAGE_PRESIGN_EXPIRES=600
