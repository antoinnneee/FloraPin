# Caddy en HTTP simple (port 80) — le TLS public est assuré par le nginx de
# l'hôte qui termine HTTPS et proxifie vers ce conteneur.
#
# (Sur ce déploiement, le port 80 public est filtré en amont et Let's Encrypt
#  passe par DNS-01 côté hôte ; Caddy ne fait donc PAS d'auto-HTTPS ici.)
#
# Même origine pour la vitrine et l'API :
#   - /api/*  -> API NestJS (préfixe global api/v1, Swagger sur /api/docs)
#   - reste   -> site statique (landing, build Astro monté dans le conteneur)

:80 {
	encode gzip

	# API FloraPin (toutes les routes sont sous /api).
	# API_PORT est injecté depuis l'environnement (défaut 3000).
	handle /api/* {
		reverse_proxy api:{$API_PORT:3000}
	}

	# Vitrine statique (build Astro) servie à la racine.
	handle {
		root * /srv/landing
		file_server
		try_files {path} {path}/ /index.html
	}
}
