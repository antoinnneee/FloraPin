---
import { BETA_NOTE, PLAY_TEST_GROUP_URL, PLAY_TEST_OPT_IN_URL } from '../config';
---

<section id="beta" class="beta-cta">
  <div class="container">
    <div class="inner reveal">
      <svg class="bloom" viewBox="0 0 44 44" width="64" height="64" aria-hidden="true">
        <g>
          <ellipse cx="22" cy="13" rx="6" ry="10" fill="var(--rose)" transform="rotate(0 22 22)" />
          <ellipse cx="22" cy="13" rx="6" ry="10" fill="var(--rose)" transform="rotate(72 22 22)" />
          <ellipse cx="22" cy="13" rx="6" ry="10" fill="var(--rose)" transform="rotate(144 22 22)" />
          <ellipse cx="22" cy="13" rx="6" ry="10" fill="var(--rose)" transform="rotate(216 22 22)" />
          <ellipse cx="22" cy="13" rx="6" ry="10" fill="var(--rose)" transform="rotate(288 22 22)" />
          <circle cx="22" cy="22" r="5.5" fill="var(--pollen)" />
        </g>
      </svg>
      <h2>Prêt à cataloguer <em>vos fleurs</em> ?</h2>
      <p>Rejoignez la bêta et soyez parmi les premiers à essayer FloraPin.</p>

      <div class="join">
        <p class="join-lead">Installez l'app en deux étapes :</p>
        <div class="join-steps">
          <a class="step-btn primary" href={PLAY_TEST_GROUP_URL} target="_blank" rel="noopener">
            <span class="step-num">1</span>
            <span class="step-label">Rejoindre le groupe de testeurs</span>
          </a>
          <a class="step-btn ghost" href={PLAY_TEST_OPT_IN_URL} target="_blank" rel="noopener">
            <span class="step-num">2</span>
            <span class="step-label">Activer l'accès bêta</span>
          </a>
        </div>
        <p class="join-hint">
          Rejoignez le groupe avec votre adresse Google, puis activez l'accès —
          FloraPin apparaît alors sur le Play&nbsp;Store.
        </p>
        <p class="join-note">{BETA_NOTE}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .beta-cta {
    padding: var(--section-py) 0;
    background: var(--papier);
  }

  .inner {
    text-align: center;
    max-width: 580px;
    margin: 0 auto;
  }

  .bloom {
    display: block;
    margin: 0 auto 24px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .bloom g {
      transform-origin: 22px 22px;
      animation: turn 24s linear infinite;
    }

    @keyframes turn {
      to { transform: rotate(360deg); }
    }
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.4vw, 2.7rem);
    font-weight: 560;
    color: var(--encre);
    line-height: 1.18;
    margin-bottom: 14px;
  }

  h2 em {
    font-style: italic;
    font-weight: 460;
    color: var(--rose);
  }

  p {
    font-size: 1.02rem;
    color: var(--texte-doux);
    margin-bottom: 36px;
  }

  /* Bloc principal : inscription au test fermé Google Play */
  .join-lead {
    font-size: 1.02rem;
    color: var(--texte);
    margin-bottom: 24px;
  }

  .join-steps {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .step-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 15px 26px;
    border-radius: 100px;
    font-weight: 700;
    font-size: 1rem;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s, border-color 0.2s;
  }

  .step-btn .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex: none;
    border-radius: 50%;
    font-size: 0.82rem;
  }

  /* Étape 1 : action principale (jaune pollen). */
  .step-btn.primary {
    background: var(--pollen);
    color: var(--encre);
    box-shadow: 0 6px 26px rgba(239, 201, 76, 0.35);
  }

  .step-btn.primary .step-num {
    background: var(--encre);
    color: var(--pollen);
  }

  .step-btn.primary:hover {
    background: var(--pollen-2);
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(239, 201, 76, 0.45);
  }

  /* Étape 2 : action secondaire (contour). */
  .step-btn.ghost {
    background: transparent;
    color: var(--feuille);
    border: 2px solid var(--tilleul-2);
  }

  .step-btn.ghost .step-num {
    background: var(--feuille);
    color: var(--papier);
  }

  .step-btn.ghost:hover {
    border-color: var(--feuille);
    transform: translateY(-2px);
  }

  .join-hint {
    font-size: 0.86rem;
    color: var(--texte-doux);
    max-width: 440px;
    margin: 22px auto 0;
  }

  .join-note {
    margin: 26px 0 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--mousse);
  }
</style>
