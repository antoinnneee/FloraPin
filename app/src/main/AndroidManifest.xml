<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions du POC, demandées en runtime (voir com.florapin.app.permission). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Notifications push (Android 13+ : demandée en runtime). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Stockage : les photos prises par l'app vont dans son répertoire privé
         (aucune permission requise). Ces permissions ne servent qu'à LIRE des
         images existantes de la galerie (import). -->
    <!-- Android 13+ (API 33+) : accès média granulaire. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Android 12 et moins : ancien modèle de stockage partagé. -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".FlorapinApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FloraPin">

        <!-- Crashlytics actif uniquement en release : la valeur de la ressource
             est fournie par build type (resValue dans build.gradle.kts). -->
        <meta-data
            android:name="firebase_crashlytics_collection_enabled"
            android:value="@bool/crashlytics_collection_enabled" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.FloraPin">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link de réinitialisation de mot de passe (NODE-116) :
                 https://florapin.pattounecorp.ovh/reset?token=... ouvre ResetPasswordScreen.
                 (App Links vérifiés nécessiteraient assetlinks.json hébergé.) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="florapin.pattounecorp.ovh"
                    android:pathPrefix="/reset" />
            </intent-filter>

            <!-- Deep link de vérification d'email (NODE-117) :
                 https://florapin.pattounecorp.ovh/verify?token=... ouvre VerifyEmailScreen. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="florapin.pattounecorp.ovh"
                    android:pathPrefix="/verify" />
            </intent-filter>
        </activity>

        <!-- Réception des push FCM (NODE-76). -->
        <service
            android:name=".push.FloraMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>
