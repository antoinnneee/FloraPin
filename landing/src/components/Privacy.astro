---
---

<section class="privacy">
  <div class="container">
    <div class="card reveal">
      <!-- Courbes de niveau, en écho au hero -->
      <svg class="card-contours" viewBox="0 0 800 400" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <g fill="none" stroke="rgba(237, 243, 227, 0.06)" stroke-width="1.5">
          <path d="M-20 320 C 160 260, 300 340, 460 290 S 720 220, 820 270" />
          <path d="M-20 240 C 180 180, 320 260, 480 210 S 740 140, 820 190" />
          <path d="M-20 160 C 200 100, 340 180, 500 130 S 760 60, 820 110" />
          <path d="M-20 80 C 220 20, 360 100, 520 50 S 780 -20, 820 30" />
        </g>
      </svg>

      <div class="card-body">
        <span class="eyebrow eyebrow-dark">Vie privée</span>
        <h2>Vos spots restent <em>secrets</em></h2>
        <p>
          Un coin rare que vous voulez garder pour vous ? À chaque partage, un simple bouton décide
          si les coordonnées GPS sont incluses ou non. Vos lieux ne quittent votre téléphone
          que si vous le décidez.
        </p>
      </div>

      <div class="demo" aria-label="Exemple de contrôle de partage GPS — essayez le bouton">
        <div class="demo-row">
          <span class="demo-label" id="gps-demo-label">Partager la localisation</span>
          <button class="toggle" id="gps-toggle" role="switch" aria-checked="false" aria-labelledby="gps-demo-label">
            <span class="thumb"></span>
          </button>
        </div>
        <div class="demo-coords">
          <span id="gps-coords">●●.●●●° N · ●.●●●° E</span>
        </div>
        <p class="demo-hint" id="gps-hint">✓ La photo est partagée, pas l'endroit</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Démo interactive : le même bouton que dans l'app décide si les
  // coordonnées GPS accompagnent la photo.
  const toggle = document.getElementById('gps-toggle');
  const coords = document.getElementById('gps-coords');
  const coordsBox = coords?.parentElement;
  const hint = document.getElementById('gps-hint');

  toggle?.addEventListener('click', () => {
    const on = toggle.getAttribute('aria-checked') !== 'true';
    toggle.setAttribute('aria-checked', String(on));
    if (coords && coordsBox && hint) {
      coords.textContent = on
        ? '45.7640° N · 4.8357° E'
        : '●●.●●●° N · ●.●●●° E';
      coordsBox.classList.toggle('shared', on);
      hint.textContent = on
        ? "✓ La photo est partagée, avec l'endroit"
        : '✓ La photo est partagée, pas l’endroit';
    }
  });
</script>

<style>
  .privacy {
    padding: var(--section-py) 0;
    background: var(--papier);
  }

  .card {
    position: relative;
    background: linear-gradient(150deg, var(--sapin) 0%, var(--encre) 90%);
    border-radius: 28px;
    padding: clamp(40px, 6vw, 72px);
    display: flex;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
    justify-content: space-between;
    overflow: hidden;
  }

  .card-contours {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .card-body {
    position: relative;
    z-index: 1;
    color: var(--tilleul);
    max-width: 520px;
  }

  .eyebrow-dark {
    color: var(--pollen);
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.8vw, 2.2rem);
    font-weight: 560;
    line-height: 1.2;
    margin-bottom: 16px;
  }

  h2 em {
    font-style: italic;
    font-weight: 460;
    color: var(--rose);
  }

  .card-body p {
    font-size: 0.98rem;
    line-height: 1.75;
    color: var(--mousse);
  }

  /* Démo toggle */
  .demo {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    background: rgba(249, 250, 244, 0.07);
    border: 1px solid rgba(249, 250, 244, 0.14);
    border-radius: 16px;
    padding: 22px 26px;
    color: var(--tilleul);
  }

  .demo-row {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 14px;
  }

  .demo-label {
    font-size: 0.88rem;
    font-weight: 700;
  }

  .toggle {
    width: 46px;
    height: 26px;
    background: rgba(249, 250, 244, 0.2);
    border: none;
    border-radius: 100px;
    padding: 3px;
    flex-shrink: 0;
    cursor: pointer;
    transition: background 0.25s;
  }

  .toggle[aria-checked="true"] {
    background: var(--pollen);
  }

  .thumb {
    display: block;
    width: 20px;
    height: 20px;
    background: var(--tilleul);
    border-radius: 50%;
    opacity: 0.85;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.25s;
  }

  .toggle[aria-checked="true"] .thumb {
    transform: translateX(20px);
    opacity: 1;
    background: var(--encre);
  }

  @media (prefers-reduced-motion: reduce) {
    .toggle, .thumb { transition: none; }
  }

  .demo-coords {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--mousse);
    background: rgba(19, 42, 29, 0.4);
    border-radius: 8px;
    padding: 8px 12px;
    margin-bottom: 12px;
    transition: color 0.25s;
  }

  .demo-coords.shared {
    color: var(--pollen);
  }

  .demo-hint {
    font-size: 0.78rem;
    color: var(--pollen);
    margin: 0;
  }

  @media (max-width: 760px) {
    .card {
      flex-direction: column;
      align-items: flex-start;
    }

    .demo { align-self: stretch; }
  }
</style>
