---
// Le sentier qui traverse toute la page : un chemin pointillé continu, du hero
// au footer, qui se dessine avec le défilement. Des fleurs éclosent au passage
// du trait et une épingle se plante au bout. Le tracé est calculé en JS d'après
// la hauteur réelle du document : un méandre sinueux (spline de Catmull-Rom)
// qui serpente de haut en bas comme un chemin de randonnée.
---

<div id="trail-overlay" aria-hidden="true">
  <svg id="trail-svg">
    <defs>
      <mask id="trail-mask" maskUnits="userSpaceOnUse">
        <path id="trail-reveal" fill="none" stroke="#fff" stroke-width="34" stroke-linecap="round" />
      </mask>
    </defs>
    <path
      id="trail-line"
      fill="none"
      stroke="#d9ae35"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-dasharray="2 12"
      mask="url(#trail-mask)"
    />
  </svg>
  <img id="trail-pin" src="/pinPoint.webp" alt="" width="72" height="72" />
</div>

<script>
  const overlay = document.getElementById('trail-overlay');
  const svg = document.getElementById('trail-svg');
  const line = document.getElementById('trail-line');
  const reveal = document.getElementById('trail-reveal');
  const pin = document.getElementById('trail-pin');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Teintes de pétales, en écho aux épingles du hero.
  const PETALS = ['#d5548c', '#f9faf4', '#c9a3e8'];
  const FLOWER_FRACTIONS = [0.1, 0.2, 0.32, 0.44, 0.56, 0.68, 0.8, 0.92];

  let pathLen = 0;
  let flowers = [];
  let target = 0;
  let cur = 0;
  let rafId = 0;

  function flowerSvg(petal) {
    const p = (r) =>
      `<ellipse cx="18" cy="8" rx="4.5" ry="7.5" fill="${petal}" transform="rotate(${r} 18 15)"/>`;
    return `<svg viewBox="0 0 36 46" width="36" height="46">
      <line class="trail-flower-stem" x1="18" y1="24" x2="18" y2="42" stroke="rgba(90,108,95,0.55)" stroke-width="2" stroke-linecap="round"/>
      <g class="trail-flower-head">${p(0)}${p(72)}${p(144)}${p(216)}${p(288)}
        <circle cx="18" cy="15" r="3.8" fill="#efc94c"/></g>
    </svg>`;
  }

  function build() {
    if (!overlay || !svg || !line || !reveal) return;
    const vw = document.documentElement.clientWidth;
    const docH = document.documentElement.scrollHeight;

    flowers.forEach((f) => f.el.remove());
    flowers = [];

    // Sur mobile, les marges disparaissent : pas de sentier en superposition.
    if (vw < 720) {
      overlay.style.display = 'none';
      return;
    }
    overlay.style.display = '';
    overlay.style.height = docH + 'px';
    svg.setAttribute('viewBox', `0 0 ${vw} ${docH}`);
    svg.setAttribute('width', String(vw));
    svg.setAttribute('height', String(docH));

    // Couloirs vides de part et d'autre du contenu centré (max-w 1160).
    const lane = Math.max(34, (vw - 1160) / 4);
    const leftX = lane;
    const rightX = vw - lane;

    const sections = [...document.querySelectorAll('main > section')];
    if (!sections.length) return;
    const hero = sections[0];
    const heroH = hero.offsetHeight;

    // Fin : au-dessus du logo « FloraPin » du footer (sinon centre bas).
    const brand = document.querySelector('.footer .logo');
    let endX, plantY;
    if (brand) {
      // Cibler le texte lui-même (le <span> est en display:block, sa boîte
      // déborde à droite) pour centrer l'épingle pile au-dessus de « FloraPin ».
      const range = document.createRange();
      range.selectNodeContents(brand);
      const r = range.getBoundingClientRect();
      endX = r.left + r.width / 2 + window.scrollX;
      plantY = r.top + window.scrollY - 6;
    } else {
      endX = vw * 0.5;
      plantY = docH - 60;
    }

    // Un sentier de randonnée : méandre continu qui serpente de haut en bas,
    // ses extrêmes venant lécher les couloirs latéraux. Deux harmoniques de
    // sinus donnent un balancement organique plutôt qu'une vague régulière.
    const center = (leftX + rightX) / 2;
    const amp = (rightX - leftX) / 2;
    const startY = heroH * 0.22;
    const meanderEndY = plantY - 80;
    const span = Math.max(1, meanderEndY - startY);
    const waves = Math.max(4, Math.round(span / 470));
    const steps = Math.max(16, waves * 5);

    // Profil « créneau adouci » : tanh(k·sin) aplatit le tracé près des bords
    // (il longe le côté et descend un peu) puis traverse plus franchement vers
    // l'autre côté, au lieu de longues diagonales. k règle la fermeté du virage.
    const K = 2.2;
    const tanhK = Math.tanh(K);

    // Départ dans la scène du hero (moitié droite).
    const pts = [[center + amp * 0.5, startY]];
    for (let i = 1; i <= steps; i++) {
      const t = i / steps;
      const y = startY + span * t;
      const swing = Math.tanh(K * Math.sin(t * Math.PI * waves - 0.35)) / tanhK;
      let x =
        center +
        amp * (0.94 * swing + 0.06 * Math.sin(t * Math.PI * waves * 2.3 + 1.1));
      // Sur le dernier sixième, rejoindre en douceur la colonne du logo.
      const approach = Math.max(0, (t - 0.83) / 0.17);
      x += (endX - x) * approach;
      x = Math.max(leftX, Math.min(rightX, x));
      pts.push([x, y]);
    }
    // Courte descente verticale pour planter l'épingle bien droite.
    pts.push([endX, plantY]);

    // Spline de Catmull-Rom convertie en Bézier : passage lisse et continu par
    // tous les points, sans cassure d'angle — un tracé qui coule.
    const f = (n) => n.toFixed(1);
    let d = `M ${f(pts[0][0])} ${f(pts[0][1])}`;
    for (let i = 0; i < pts.length - 1; i++) {
      const p0 = pts[i - 1] || pts[i];
      const p1 = pts[i];
      const p2 = pts[i + 1];
      const p3 = pts[i + 2] || p2;
      const c1x = p1[0] + (p2[0] - p0[0]) / 6;
      const c1y = p1[1] + (p2[1] - p0[1]) / 6;
      const c2x = p2[0] - (p3[0] - p1[0]) / 6;
      const c2y = p2[1] - (p3[1] - p1[1]) / 6;
      d += ` C ${f(c1x)} ${f(c1y)}, ${f(c2x)} ${f(c2y)}, ${f(p2[0])} ${f(p2[1])}`;
    }
    line.setAttribute('d', d);
    reveal.setAttribute('d', d);

    pathLen = line.getTotalLength();
    reveal.setAttribute('stroke-dasharray', String(pathLen));
    reveal.setAttribute('stroke-dashoffset', String(pathLen * (1 - cur)));

    // Fleurs posées le long du tracé.
    for (let i = 0; i < FLOWER_FRACTIONS.length; i++) {
      const f = FLOWER_FRACTIONS[i];
      const pt = line.getPointAtLength(pathLen * f);
      const el = document.createElement('div');
      el.className = 'trail-flower';
      el.style.left = pt.x + 'px';
      el.style.top = pt.y + 'px';
      el.innerHTML = flowerSvg(PETALS[i % PETALS.length]);
      overlay.appendChild(el);
      flowers.push({ el, f });
    }

    // Épingle plantée au tout bout du sentier (centre du footer).
    if (pin) {
      const end = line.getPointAtLength(pathLen);
      pin.style.left = end.x + 'px';
      pin.style.top = end.y + 'px';
    }
  }

  function computeTarget() {
    const docH = document.documentElement.scrollHeight;
    const vh = window.innerHeight;
    // La pointe du trait suit la position de lecture (~milieu haut de l'écran)
    // plutôt que le bas : le sentier reste au niveau du regard et se dessine au
    // rythme du défilement, sans prendre une longueur d'avance.
    const lead = vh * 0.45;
    // Dénominateur réduit d'autant : la pointe atteint 100 % pile en bas de page.
    target = Math.min(1, (window.scrollY + lead) / Math.max(1, docH - vh + lead));
  }

  function apply(progress) {
    if (!reveal) return;
    reveal.setAttribute('stroke-dashoffset', String(pathLen * (1 - progress)));
    for (const fl of flowers) {
      fl.el.classList.toggle('bloomed', progress >= fl.f);
    }
    // L'épingle se plante quand le trait arrive tout au bout.
    if (pin) pin.classList.toggle('dropped', progress >= 0.995);
  }

  let lastTime = 0;
  function tick(now) {
    // Lissage exponentiel + vitesse plafonnée (indépendant du framerate) :
    // un scroll éclair ne révèle pas tout d'un coup, le trait « rattrape »
    // à 0,28 page/s au plus (~3,5 s pour traverser toute la page).
    const dt = lastTime ? Math.min(0.05, (now - lastTime) / 1000) : 0.016;
    lastTime = now;
    const MAX_SPEED = 0.28;
    let delta = (target - cur) * (1 - Math.exp(-3.2 * dt));
    const maxStep = MAX_SPEED * dt;
    delta = Math.max(-maxStep, Math.min(maxStep, delta));
    cur += delta;
    if (Math.abs(target - cur) < 0.0005) cur = target;
    apply(cur);
    rafId = requestAnimationFrame(tick);
  }

  if (overlay && line && reveal) {
    build();
    computeTarget();
    if (reduced) {
      // Pas d'animation liée au défilement : sentier et fleurs visibles.
      cur = 1;
      apply(1);
    } else {
      window.addEventListener('scroll', computeTarget, { passive: true });
      rafId = requestAnimationFrame(tick);
    }

    // Rebâtir quand la mise en page change (resize, chargement des fontes).
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        build();
        computeTarget();
        if (reduced) apply(1);
      }, 150);
    });
    window.addEventListener('load', () => {
      build();
      computeTarget();
      if (reduced) apply(1);
    });
  }
</script>

<style is:global>
  #trail-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  /* Le sentier passe DERRIÈRE les cartes de contenu : on remonte le contenu des
     sections (hors hero, où le tracé doit rester au premier plan) au-dessus du
     tracé. Les zones transparentes laissent voir le sentier ; les cartes opaques
     le masquent — d'où l'effet « chemin qui se faufile entre les blocs ». */
  main > section:not(.hero) > .container,
  body > footer > .container {
    position: relative;
    z-index: 2;
  }

  #trail-line {
    opacity: 0.8;
  }

  .trail-flower {
    position: absolute;
    transform: translate(-50%, -88%);
    filter: drop-shadow(0 3px 8px rgba(19, 42, 29, 0.25));
  }

  #trail-pin {
    position: absolute;
    /* La pointe de l'épingle (bas-centre de l'image) tombe pile sur le bout du trait. */
    transform: translate(-50%, -100%) scale(0.6);
    transform-origin: 50% 100%;
    opacity: 0;
    filter: drop-shadow(0 4px 10px rgba(19, 42, 29, 0.3));
    transition:
      transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.3s ease;
  }

  #trail-pin.dropped {
    transform: translate(-50%, -100%) scale(0.9);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    #trail-pin {
      transition: none;
    }
  }

  /* La tige pousse d'abord (du sol vers le haut)… */
  .trail-flower .trail-flower-stem {
    transform-origin: 18px 42px;
    transform: scaleY(0);
    opacity: 0;
    transition:
      transform 0.4s ease-out,
      opacity 0.2s ease;
  }

  .trail-flower.bloomed .trail-flower-stem {
    transform: scaleY(1);
    opacity: 1;
  }

  /* …puis la corolle éclot, avec un léger retard. */
  .trail-flower .trail-flower-head {
    transform-origin: 18px 15px;
    transform: scale(0);
    opacity: 0;
    transition:
      transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.18s,
      opacity 0.35s ease 0.18s;
  }

  .trail-flower.bloomed .trail-flower-head {
    transform: scale(1);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .trail-flower .trail-flower-stem,
    .trail-flower .trail-flower-head {
      transition: none;
    }
  }
</style>
