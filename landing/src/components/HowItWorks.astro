---
const steps = [
  {
    number: '01',
    icon: '📷',
    title: 'Photographier',
    desc: "Ouvrez l'app et prenez une photo de la fleur.",
  },
  {
    number: '02',
    icon: '📍',
    title: 'Localiser',
    desc: 'Sa position est enregistrée automatiquement et apparaît sur votre carte.',
  },
  {
    number: '03',
    icon: '🤝',
    title: 'Partager',
    desc: 'Publiez vos trouvailles dans le flux de vos amis, recevez leurs cœurs et leur aide pour identifier les espèces.',
  },
];
---

<section class="how">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Comment ça marche</span>
      <h2>En trois étapes simples</h2>
    </div>
    <div class="steps">
      {steps.map((step, i) => (
        <>
          <div class="step">
            <div class="step-num">{step.number}</div>
            <div class="step-icon">{step.icon}</div>
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
          {i < steps.length - 1 && (
            <div class="arrow" aria-hidden="true">→</div>
          )}
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .how {
    padding: var(--section-py) 0;
    background: linear-gradient(180deg, var(--green-50) 0%, var(--white) 100%);
  }

  .steps {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: start;
    gap: 0;
  }

  .step {
    text-align: center;
    padding: 0 12px;
  }

  .step-num {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--green-600);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .step-icon {
    font-size: 2.2rem;
    width: 68px;
    height: 68px;
    background: var(--white);
    border: 2px solid var(--green-200);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    box-shadow: 0 4px 16px rgba(34, 197, 94, 0.1);
  }

  h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--green-900);
    margin-bottom: 8px;
  }

  p {
    font-size: 0.88rem;
    color: var(--gray-600);
    line-height: 1.7;
    max-width: 220px;
    margin: 0 auto;
  }

  .arrow {
    font-size: 1.6rem;
    color: var(--green-200);
    align-self: start;
    padding-top: 36px;
  }

  @media (max-width: 680px) {
    .steps {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .arrow { display: none; }
    p { max-width: 100%; }
  }
</style>
